# ============================================================
# BankStack — Unified Wazuh + Splunk Banking SOC Deployment
# Environment Configuration
# ============================================================
# Copy this file to .env and adjust values as needed
# cp .env.example .env

# --- Wazuh Configuration ---
WAZUH_VERSION=4.9.2
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=CHANGE_ME_wazuh_api_pw      # min 8 chars; used by dashboard + test scripts
WAZUH_CLUSTER_KEY=CHANGE_ME_32hex              # 32-char hex; see README for generation

# --- Wazuh Indexer ---
INDEXER_URL=https://wazuh-indexer:9200
INDEXER_USERNAME=admin
INDEXER_PASSWORD=admin

# --- Splunk Configuration ---
SPLUNK_VERSION=9.3
SPLUNK_PASSWORD=CHANGE_ME_splunk_pw             # min 8 chars; Splunk admin password
SPLUNK_HEC_TOKEN=CHANGE_ME_uuid                # must match splunk/apps/bankstack/default/inputs.conf

# --- Network ---
WAZUH_MANAGER_IP=wazuh-manager
SPLUNK_HOST=splunk
SPLUNK_SYSLOG_PORT=9515

# --- Simulator ---
SIMULATOR_LOG_RATE=10
SIMULATOR_ATTACK_PROBABILITY=0.15
SIMULATOR_CBS_TYPE=ababil

# --- Compose Project ---
COMPOSE_PROJECT_NAME=bankstack
