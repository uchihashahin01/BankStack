<!--
  ================================================================
  BankStack — Custom Banking Rules for Bangladesh SOC
  ================================================================
  Rule ID Ranges:
    100100-100109 : Authentication & Access Control
    100110-100119 : Brute Force & Account Abuse
    100120-100129 : Privilege Escalation
    100130-100139 : Web Application Attacks
    100140-100149 : File Integrity (SWIFT)
    100150-100159 : File Integrity (CBS)
    100160-100169 : File Integrity (Payment Systems)
    100200-100219 : SWIFT Operations
    100220-100239 : CBS Operations
    100240-100259 : MFS (bKash/Nagad/Rocket)
    100260-100279 : BEFTN/NPSB/RTGS
    100280-100289 : ATM/POS Operations
    100290-100299 : Agent Banking
    100300-100319 : Compliance (BB ICT v4.0 / PCI DSS)
    100320-100329 : Data Exfiltration
    100330-100339 : Insider Threat
    100340-100349 : Network Anomalies
    100400-100409 : Card Fraud
    100410-100419 : QR Payment (Binimoy)
  ================================================================
-->

<group name="bankstack,">

  <!-- ========================================================
       AUTHENTICATION & ACCESS CONTROL (100100-100109)
       ======================================================== -->

  <rule id="100100" level="5">
    <decoded_as>bankstack-auth</decoded_as>
    <match>LOGIN_FAILED</match>
    <description>BankStack: Failed login attempt to banking system</description>
    <group>authentication_failed,banking,</group>
  </rule>

  <rule id="100101" level="10">
    <decoded_as>bankstack-auth</decoded_as>
    <match>LOGIN_FAILED</match>
    <field name="system">CBS|SWIFT|RTGS</field>
    <description>BankStack: Failed login to critical banking system (CBS/SWIFT/RTGS)</description>
    <group>authentication_failed,banking,critical_system,</group>
  </rule>

  <rule id="100102" level="12">
    <decoded_as>bankstack-auth</decoded_as>
    <match>LOGIN_SUCCESS</match>
    <time>22:00-06:00</time>
    <field name="system">CBS|SWIFT</field>
    <description>BankStack: After-hours login to critical banking system</description>
    <group>authentication_success,banking,after_hours,</group>
  </rule>

  <rule id="100103" level="10">
    <decoded_as>bankstack-auth</decoded_as>
    <match>LOGIN_SUCCESS</match>
    <field name="source_country">!BD</field>
    <field name="system">CBS|SWIFT|RTGS</field>
    <description>BankStack: Non-Bangladesh IP accessed critical banking system</description>
    <group>authentication_success,banking,geo_anomaly,</group>
  </rule>

  <rule id="100104" level="8">
    <decoded_as>bankstack-auth</decoded_as>
    <match>LOGIN_SUCCESS</match>
    <field name="user_type">service_account</field>
    <description>BankStack: Service account interactive login detected</description>
    <group>authentication_success,banking,service_account,</group>
  </rule>

  <rule id="100105" level="12">
    <decoded_as>bankstack-auth</decoded_as>
    <match>PASSWORD_CHANGE</match>
    <field name="user_role">admin|dba|swift_operator</field>
    <description>BankStack: Privileged banking account password changed</description>
    <group>account_change,banking,privileged,</group>
  </rule>

  <rule id="100106" level="14">
    <decoded_as>bankstack-auth</decoded_as>
    <match>MFA_BYPASS</match>
    <description>BankStack: MFA bypass attempt on banking system</description>
    <group>authentication_failed,banking,mfa_bypass,</group>
  </rule>

  <rule id="100107" level="10">
    <decoded_as>bankstack-auth</decoded_as>
