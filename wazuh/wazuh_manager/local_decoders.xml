<!--
  ================================================================
  BankStack — Custom Decoders for Bangladesh Banking Logs
  ================================================================
-->

<!-- Authentication Decoder -->
<decoder name="bankstack-auth">
  <prematch>^BANKSTACK_AUTH:</prematch>
</decoder>
<decoder name="bankstack-auth-fields">
  <parent>bankstack-auth</parent>
  <regex offset="after_parent">(\S+) user=(\S+) src=(\S+) system=(\S+) user_type=(\S+) source_country=(\S+)</regex>
  <order>action, user, srcip, system, user_type, source_country</order>
</decoder>
<decoder name="bankstack-auth-role">
  <parent>bankstack-auth</parent>
  <regex offset="after_parent">(\S+) user=(\S+) user_role=(\S+) new_role=(\S+)</regex>
  <order>action, user, user_role, new_role</order>
</decoder>

<!-- SWIFT Decoder -->
<decoder name="bankstack-swift">
  <prematch>^BANKSTACK_SWIFT:</prematch>
</decoder>
<decoder name="bankstack-swift-fields">
  <parent>bankstack-swift</parent>
  <regex offset="after_parent">(\S+) msg_type=(\S+) sender=(\S+) receiver=(\S+) amount_usd=(\S+) dest_country=(\S+) user=(\S+)</regex>
  <order>action, msg_type, sender_bic, receiver_bic, amount_usd, dest_country, user</order>
</decoder>

<!-- CBS Decoder -->
<decoder name="bankstack-cbs">
  <prematch>^BANKSTACK_CBS:</prematch>
</decoder>
<decoder name="bankstack-cbs-fields">
  <parent>bankstack-cbs</parent>
  <regex offset="after_parent">(\S+) txn_type=(\S+) account=(\S+) amount_bdt=(\S+) user=(\S+) branch=(\S+)</regex>
  <order>action, txn_type, account, amount_bdt, user, branch</order>
</decoder>
<decoder name="bankstack-cbs-mod">
  <parent>bankstack-cbs</parent>
  <regex offset="after_parent">(\S+) field_changed=(\S+) account=(\S+) user=(\S+) beneficiary_type=(\S+)</regex>
  <order>action, field_changed, account, user, beneficiary_type</order>
</decoder>

<!-- MFS Decoder (bKash/Nagad/Rocket) -->
<decoder name="bankstack-mfs">
  <prematch>^BANKSTACK_MFS:</prematch>
</decoder>
<decoder name="bankstack-mfs-fields">
  <parent>bankstack-mfs</parent>
  <regex offset="after_parent">(\S+) provider=(\S+) phone=(\S+) txn_type=(\S+) amount_bdt=(\S+) agent_id=(\S+)</regex>
  <order>action, provider, phone_number, txn_type, amount_bdt, agent_id</order>
</decoder>

